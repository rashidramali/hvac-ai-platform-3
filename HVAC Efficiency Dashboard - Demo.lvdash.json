{
  "datasets": [
    {
      "name": "58a6808d",
      "displayName": "kpi_summary",
      "queryLines": [
        "SELECT\r\n",
        "  ROUND(AVG(avg_actual_power_kw), 2) AS avg_actual_power_kw,\r\n",
        "  ROUND(AVG(avg_baseline_power_kw), 2) AS avg_baseline_power_kw,\r\n",
        "  ROUND(AVG(avg_power_saving_pct), 2) AS avg_power_saving_pct,\r\n",
        "  ROUND(SUM(estimated_energy_saved_kwh), 2) AS total_energy_saved_kwh,\r\n",
        "  ROUND(SUM(estimated_cost_saved_rm), 2) AS total_cost_saved_rm\r\n",
        "FROM hvacapp_dev3.curated.gold_hvac_daily_savings_v3;"
      ]
    },
    {
      "name": "984bac61",
      "displayName": "trend_actual_vs_baseline_power",
      "queryLines": [
        "SELECT\r\n",
        "  event_ts,\r\n",
        "  actual_power_kw,\r\n",
        "  baseline_power_kw\r\n",
        "FROM hvacapp_dev3.curated.gold_hvac_interval_savings\r\n",
        "ORDER BY event_ts;"
      ]
    },
    {
      "name": "a9907bd5",
      "displayName": "trend_power_saving",
      "queryLines": [
        "SELECT\r\n",
        "  event_ts,\r\n",
        "  power_saving_kw,\r\n",
        "  power_saving_pct\r\n",
        "FROM hvacapp_dev3.curated.gold_hvac_interval_savings\r\n",
        "ORDER BY event_ts;"
      ]
    },
    {
      "name": "db80ad66",
      "displayName": "daily_savings_summary",
      "queryLines": [
        "SELECT\r\n",
        "  event_date,\r\n",
        "  avg_actual_power_kw,\r\n",
        "  avg_baseline_power_kw,\r\n",
        "  avg_power_saving_kw,\r\n",
        "  avg_power_saving_pct,\r\n",
        "  estimated_energy_saved_kwh,\r\n",
        "  estimated_cost_saved_rm\r\n",
        "FROM hvacapp_dev3.curated.gold_hvac_daily_savings_v3\r\n",
        "ORDER BY event_date;"
      ]
    },
    {
      "name": "8a640654",
      "displayName": "daily_kpi_table",
      "queryLines": [
        "SELECT\r\n",
        "  event_date,\r\n",
        "  site_id,\r\n",
        "  building_id,\r\n",
        "  hvac_system_id,\r\n",
        "  avg_actual_power_kw,\r\n",
        "  avg_baseline_power_kw,\r\n",
        "  avg_power_saving_kw,\r\n",
        "  avg_power_saving_pct,\r\n",
        "  estimated_energy_saved_kwh,\r\n",
        "  estimated_cost_saved_rm,\r\n",
        "  total_records\r\n",
        "FROM hvacapp_dev3.curated.gold_hvac_daily_savings_v3\r\n",
        "ORDER BY event_date DESC;"
      ]
    }
  ],
